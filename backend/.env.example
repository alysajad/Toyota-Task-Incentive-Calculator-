# ---- Backend environment ----
# Copy to backend/.env for local dev. NEVER commit the real .env.

# Generate a strong key for production, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=django-insecure-dev-only-change-me

# dev settings default DEBUG=True; set False for prod-like runs.
DEBUG=True

# Comma-separated. In production set to your API host(s).
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave blank to use local SQLite. To use Supabase / Postgres, paste the
# connection string (Supabase: Project Settings → Database → Connection string,
# "URI"; use the pooler URI for serverless). Example:
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=
# Supabase requires SSL (default True). Set False only for a local non-SSL DB.
DB_SSL_REQUIRE=True
# Set true ONLY if using Supabase's transaction pooler (port 6543). Leave false
# for the session pooler (port 5432) or a direct connection.
PGBOUNCER=False

# Optional shared cache. Leave blank for the built-in local-memory cache.
# Use Redis in production for cache sharing across workers/instances.
# Example: redis://default:<password>@<host>:6379/0
CACHE_URL=
CACHE_DEFAULT_TIMEOUT=300
CACHE_ANALYTICS_TIMEOUT=60
CACHE_REFERENCE_TIMEOUT=300

# Frontend origin(s) allowed by CORS (prod). Dev allows all localhost.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public demo-login helper. Set DEMO_CREDENTIALS_ENABLED=False for private apps.
# Passwords are applied to real users as Django hashes; the UI helper rows are
# fetched from the database and validated against those hashes.
DEMO_CREDENTIALS_ENABLED=True
DEMO_ADMIN_EMAIL=admin@nippon.test
DEMO_ADMIN_PASSWORD=Admin@12345
DEMO_OFFICER_EMAIL=ravi.officer@nippon.test
DEMO_OFFICER_PASSWORD=Officer@12345
